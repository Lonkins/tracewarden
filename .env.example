# tracewarden demo stack configuration — copy to .env (never commit .env)

# OTLP endpoint the instrumented app exports to (docker-compose collector default)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name stamped on spans
OTEL_SERVICE_NAME=my-agent

# Optional: opt-in local LLM detector backend (Ollama)
# TRACEWARDEN_LLM_DETECTOR_URL=http://localhost:11434
